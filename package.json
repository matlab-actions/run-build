{
    "name": "run-matlab-build-action",
    "author": "The MathWorks, Inc.",
    "version": "2.3.0",
    "description": "",
    "main": "lib/index.js",
    "scripts": {
        "clean": "rm -rf dist lib",
        "format": "prettier --write .",
        "format-check": "prettier --check .",
        "build": "tsc",
        "deps": "bash ./scripts/setupdeps.sh",
        "package": "ncc build --minify",
        "test": "jest",
        "all": "npm test && npm run build && npm run package",
        "ci": "npm run clean && npm run deps && npm ci && npm run all"
    },
    "files": [
        "lib/"
    ],
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/exec": "^1.1.1",
        "run-matlab-command-action": "github:matlab-actions/run-command#v2.1.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^22.1.0",
        "@types/uuid": "^10.0.0",
        "@vercel/ncc": "^0.38.1",
        "jest": "^29.7.0",
        "jest-circus": "^29.7.0",
        "prettier": "3.3.3",
        "ts-jest": "^29.2.4",
        "typescript": "^5.5.4"
    }
}
